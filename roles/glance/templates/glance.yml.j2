server:
  port: 8080
  proxied: true

theme:
  background-color: 231 15 21
  primary-color: 265 89 79
  contrast-multiplier: 1.2
  positive-color: 135 94 66
  negative-color: 0 100 67
  disable-picker: true

pages:
  - name: Home
    columns:
      - size: small
        widgets:
          - type: twitch-channels
            cache: 5m
            channels:
              - Ka6an4ik_
              - fnjke00
              - LenaGol0vach
              - SilverName
              - JoinTheSystemm
            collapse-after: 5

          - type: docker-containers
            format-container-names: true

      - size: full
        widgets:
          - type: rss
            title: Meduza
            cache: 10m
            feeds:
              - url: https://meduza.io/rss/all
                title: Meduza
            limit: 15
            collapse-after: 5

          - type: hacker-news
            cache: 30m
            limit: 15
            collapse-after: 5

          - type: rss
            title: Gizmochina
            cache: 10m
            feeds:
              - url: https://gizmochina.com/category/news/feed
                title: Gizmochina
            limit: 15
            collapse-after: 5

          - type: group
            widgets:
              - type: reddit
                subreddit: LETFs
                cache: 30m
                style: vertical-list
                show-thumbnails: true
                limit: 20
                collapse-after: 10

              - type: reddit
                subreddit: wallstreetbets
                cache: 30m
                style: vertical-list
                show-thumbnails: true
                limit: 20
                collapse-after: 10

              - type: reddit
                subreddit: selfhosted
                cache: 30m
                style: vertical-list
                show-thumbnails: true
                limit: 20
                collapse-after: 10

      - size: small
        widgets:
          - type: weather
            location: Batumi, Georgia
            units: metric
            hour-format: 24h

          - type: releases
            title: GitHub Releases
            cache: 1h
            repositories:
              - insin/control-panel-for-twitter
            token: ${GITHUB_TOKEN}
            limit: 10
            collapse-after: 5

          - type: markets
            cache: 5m
            markets:
              - symbol: SPY
                name: SPY
              - symbol: BTC-USD
                name: BTC
              - symbol: QQQ
                name: QQQ
              - symbol: TQQQ
                name: TQQQ
              - symbol: INFQ
                name: INFQ

          - type: monitor
            title: Services
            cache: 1m
            sites:
              - title: OpenCloud
                url: https://cloud.{{ server_hostname }}
                check-url: http://opencloud:9200
                icon: si:nextcloud
              - title: Gitea
                url: https://git.{{ server_hostname }}
                check-url: http://gitea:3000
                icon: si:gitea
              - title: Navidrome
                url: https://navidrome.{{ server_hostname }}
                check-url: http://navidrome:4533
                icon: si:navidrome
              - title: Portainer
                url: https://portainer.{{ server_hostname }}
                check-url: http://portainer:9000
                icon: si:portainer
              - title: Docs
                url: https://docs.{{ server_hostname }}
                check-url: http://mkdocs:8000
                icon: si:materialformkdocs
              - title: ConvertX
                url: https://convert.{{ server_hostname }}
                check-url: http://convertx:3000
                icon: si:files
              - title: BentoPDF
                url: https://pdf.{{ server_hostname }}
                check-url: http://bentopdf:8080
                icon: si:adobeacrobatreader
              - title: TG AI Manager
                url: https://tg.{{ server_hostname }}
                check-url: http://tg-ai-manager:8000
                icon: si:telegram

          - type: calendar
            first-day-of-week: monday
